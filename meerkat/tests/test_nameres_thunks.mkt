// test_nameres_thunks.mkt
//
// This test file contains reproductions for name resolution of thunks
// and suspended computations, showing what should fail and what should
// pass. The failing cases must be commented out to run the valid cases

// Example 1: Direct IIFE (Closure)
// Expected behavior: FAILS static check due to immediate forward reference 'x'
service s1 {
    def y = (fn () => x + 1) ();
   var x = 5;
}

// Example 2: Indirect Function Call (Closure)
// Expected behavior: FAILS static check due to immediate forward reference 'x'
service s2 {
    def f = fn () => x + 1;
    def y = f();
    var x = 5;
}

// Example 3: Safe nested action closure (returned but not immediately executed)
// Expected behavior: PASSES static check as the action is not executed during init
service s3 {
    def act_closure = fn () => action { x = x + 1; };
    def y = act_closure();
    var x = 5;
}

// Example 4: Safe forward reference inside closure that is not called during init
// Expected behavior: PASSES static check as the closure body is deferred
service s4 {
    def f = fn () => x + 1;
    var x = 5;
}
